DATABASE_URL=postgresql://user:password@localhost:5432/mydatabase
# Al arranque se aplica ALTER en users si falta email_verified_at (BDs creadas antes).
SECRET_KEY=replace-with-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_ORIGINS=http://localhost:3000
# En true permite POST /api/users/ sin JWT (ideal para probar en /docs).
ALLOW_PUBLIC_SIGNUP=false
# En true el login (y la renovación por refresh) falla hasta marcar el correo con POST /api/auth/verify-email.
REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=false

PUBLIC_FRONTEND_URL=http://localhost:3000
EMAIL_VERIFICATION_EXPIRE_HOURS=48
PASSWORD_RESET_EXPIRE_MINUTES=60

# true = no se usa SMTP; el cuerpo del mail (enlace de verificación / reset) se escribe en la consola del servidor (WARNING).
MAIL_SUPPRESS=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
