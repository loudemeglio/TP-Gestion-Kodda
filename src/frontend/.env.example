# API de Gemini para autocompletar "Publicar prenda" con IA (opcional).
# Obtené una key en https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=

# Solo si el frontend no usa setupProxy (p. ej. build estático). En dev con npm start suele ir vacío.
# Para probar pago QR desde el celular en la misma Wi‑Fi, dejá vacío y configurá PUBLIC_FRONTEND_URL en el backend.
# REACT_APP_API_URL=http://localhost:8000

# Fallback si el backend no devuelve payment_url (opcional). En Vercel suele alcanzar window.location.origin.
# Local + celular: http://TU_IP_LAN:3000 (misma IP que PUBLIC_FRONTEND_URL del backend)
# REACT_APP_PUBLIC_ORIGIN=http://192.168.0.152:3000
